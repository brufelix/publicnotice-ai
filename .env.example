# ─────────────────────────────────────────────────────────────
# publicnotice-ai · variáveis de ambiente
# ─────────────────────────────────────────────────────────────
# Copie este arquivo para `.env` e ajuste os valores.
#
# Em produção (Railway):
#   - DATABASE_URL é injetada automaticamente pelo plugin Postgres
#   - LLM_PROVIDER=groq (ou gemini/openai) — Ollama não roda bem na Railway
#   - Defina as API keys correspondentes
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── Database (Postgres + pgvector) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/publicnotice

# ─── LLM ─────────────────────────────────────────────────────
# Provider: ollama (default em dev) | groq | gemini | openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b

# Ollama (dev local)
OLLAMA_BASE_URL=http://ollama:11434

# Groq (recomendado em produção — free tier 14.4k req/dia)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ─── Embeddings ──────────────────────────────────────────────
# Provider: ollama (default em dev) | gemini | openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768          # nomic-embed-text=768 | text-embedding-3-small=1536

# ─── Storage de PDFs ─────────────────────────────────────────
STORAGE_PATH=./storage            # local; em prod usar S3/R2

# ─── Frontend (apps/web) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
